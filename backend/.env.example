PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
# Public site URL used for generated invitation/dashboard links.
# Local: http://localhost:5173
# Railway production: https://momoevent.up.railway.app
CLIENT_URL=http://localhost:5173

# Twilio WhatsApp (bulk send from server)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
# Virtual WhatsApp sender — must include whatsapp: prefix, e.g. whatsapp:+14155238886
TWILIO_PHONE_NUMBER=whatsapp:+9725XXXXXXXX

# Twilio compliance webhook (Twilio Console → HTTP, no trailing slash):
# https://momoevent.up.railway.app/api/webhooks/twilio-compliance
